# ─── Application ───
APP_NAME=HR Gallery
APP_ENV=production

# ─── Backend ───
BACKEND_PORT=8000
BACKEND_WORKERS=4
MAX_UPLOAD_SIZE_MB=50
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ─── Frontend ───
NEXT_PUBLIC_API_URL=/api

# ─── Googer ───
GOOGER_DEFAULT_REGION=us-en
GOOGER_DEFAULT_MAX_RESULTS=10
GOOGER_TIMEOUT=15
GOOGER_MAX_RETRIES=3

# ─── f2a ───
F2A_MAX_FILE_SIZE_MB=50
F2A_DEFAULT_LANG=en
F2A_UPLOAD_DIR=/app/uploads
