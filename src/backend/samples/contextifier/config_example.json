{
  "company": "TechCorp AI Solutions",
  "version": "2.5.0",
  "environment": "production",
  "database": {
    "host": "db.example.com",
    "port": 5432,
    "name": "techcorp_prod",
    "pool_size": 20,
    "max_overflow": 10,
    "ssl_enabled": true
  },
  "api": {
    "base_url": "https://api.techcorp.ai",
    "timeout_seconds": 30,
    "rate_limit": {
      "requests_per_minute": 1000,
      "burst_limit": 50
    },
    "endpoints": [
      {
        "name": "document-extract",
        "path": "/v2/extract",
        "method": "POST",
        "max_file_size_mb": 100
      },
      {
        "name": "text-chunk",
        "path": "/v2/chunk",
        "method": "POST",
        "max_chunk_size": 5000
      },
      {
        "name": "batch-process",
        "path": "/v2/batch",
        "method": "POST",
        "max_files": 50
      }
    ]
  },
  "processing": {
    "default_chunk_size": 1000,
    "default_overlap": 200,
    "supported_languages": ["ko", "en", "ja", "zh"],
    "ocr_engines": ["openai", "anthropic", "gemini", "bedrock", "vllm"],
    "table_formats": ["html", "markdown", "text"],
    "max_concurrent_jobs": 8
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s %(name)s %(levelname)s %(message)s",
    "handlers": ["console", "file", "sentry"],
    "file_path": "/var/log/techcorp/app.log",
    "rotation": "daily",
    "retention_days": 30
  },
  "features": {
    "ocr_enabled": true,
    "table_detection": true,
    "image_extraction": true,
    "metadata_extraction": true,
    "smart_chunking": true,
    "deduplication": true
  }
}
